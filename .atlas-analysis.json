  "keyFeatures": [
    "Resource-based API client with package-per-resource structure",
    "HTTP middleware for Bearer token authentication (WithHeaderAuthorization, RequireHeaderAuthorization)",
    "JWT verification and decoding with JWKS caching",
    "Session claims extraction and organization permission/role checks",
    "Support for both package-level (single key) and client-based (multi-key) usage patterns",
    "Session reverification middleware and policy enforcement",
    "Custom claims support via constructor functions",
    "Comprehensive error handling via APIErrorResponse with trace IDs",
    "Testable backend interface with mock-friendly design"
  ],
  "publicApiSurface": [
    "clerk.SetKey(key string)",
    "clerk.NewBackend(config *BackendConfig) Backend",
    "clerk.GetBackend() Backend",
    "clerk.SetBackend(b Backend)",
    "clerk.SessionClaimsFromContext(ctx context.Context) (*SessionClaims, bool)",
    "clerk.ContextWithSessionClaims(ctx context.Context, value any) context.Context",
    "clerk.SessionClaims.HasPermission(permission string) bool",
    "clerk.SessionClaims.HasRole(role string) bool",
    "clerk.SessionClaims.NeedsReverification(policy SessionReverificationPolicy) bool",
    "jwt.Verify(ctx context.Context, params *VerifyParams) (*clerk.SessionClaims, error)",
    "jwt.Decode(ctx context.Context, params *DecodeParams) (*clerk.UnverifiedToken, error)",
    "jwt.GetJSONWebKey(ctx context.Context, params *GetJSONWebKeyParams) (*clerk.JSONWebKey, error)",
    "http.WithHeaderAuthorization(opts ...AuthorizationOption) func(http.Handler) http.Handler",
    "http.RequireHeaderAuthorization(opts ...AuthorizationOption) func(http.Handler) http.Handler",
    "http.NeedsSessionReverification(policy clerk.SessionReverificationPolicy) func(http.Handler) http.Handler",
    "user.Create / user.Get / user.Update / user.Delete / user.List",
    "organization.Create / organization.Get / organization.Update / organization.Delete / organization.List",
    "session.Get / session.List / session.Revoke",
    "organizationmembership.Create / organizationmembership.List / organizationmembership.Update / organizationmembership.Delete",
    "invitation.Create / invitation.BulkCreate / invitation.List / invitation.Revoke",
    "signintoken.Create",
    "domain.Create / domain.Delete / domain.List",
    "samlconnection.Create / samlconnection.Get / samlconnection.Update / samlconnection.Delete / samlconnection.List",
    "allowlistidentifier.Create / allowlistidentifier.Delete / allowlistidentifier.List",
    "blocklistidentifier.Create / blocklistidentifier.Delete / blocklistidentifier.List",
    "jwks.Get",
    "instancesettings.Get / instancesettings.Update",
    "waitlistentry.Create / waitlistentry.List",
    "oauthapplication.Create / oauthapplication.Get / oauthapplication.Update / oauthapplication.Delete / oauthapplication.List"
  ]
